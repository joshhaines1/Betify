{
  "expo": {
    "name": "Betify",
    "slug": "Betify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/BetifyAppLogoLight.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "icons": {
        "dark": "./assets/icons/BetifyAppLogoDark.png",
        "light": "./assets/icons/BetifyAppLogoLight.png"
      },
      "bundleIdentifier": "com.joshhaines.Betify",
    "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.joshhaines.Betify"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/BetifyAppLogoDark.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "black"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
